<?xml version="1.0" encoding="UTF-8"?>
<!--
  ING AutoLister - WiX installer
  Build:  wix build installer.wxs -d SourceDir=.\ING eBay AutoLister\dist\ -o installer-out\ING-AutoLister-Setup.msi
  Prereq: dotnet tool install -g wix

  Installs per-machine (requires UAC / admin elevation).
    Exe      -> %ProgramFiles%\ING Mining\ING AutoLister\
    Service  -> INGAutoLister  (auto-start at boot, LocalSystem)
    Startup  -> HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\Run (all users)
    Data     -> C:\ProgramData\ING AutoLister\  (app auto-creates on first run)
  Shortcuts: Desktop, Start Menu
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package Name="ING AutoLister"
           Manufacturer="ING Mining LLC"
           Version="2.0.0.0"
           UpgradeCode="{7A8F9B2C-3D4E-5F60-A1B2-C3D4E5F6A7B8}"
           Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of ING AutoLister is already installed." />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <!-- Install directory: C:\Program Files\ING Mining\ING AutoLister\ -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="ING_MINING_DIR" Name="ING Mining">
        <Directory Id="INSTALLFOLDER" Name="ING AutoLister">

          <!-- Main executable + Windows service registration -->
          <Component Id="MainExeComp" Guid="{A2B3C4D5-E6F7-0001-1234-567890ABCDEF}">
            <File Id="MainExeFile"
                  Source="$(var.SourceDir)AutoListerB1.exe"
                  KeyPath="yes"
                  Checksum="yes" />

            <!-- Windows service: auto-starts at boot as LocalSystem -->
            <ServiceInstall Id="INGAutoListerSvc"
                            Name="INGAutoLister"
                            DisplayName="ING AutoLister"
                            Description="ING Listing Engine - web server on localhost:9331 by ING Mining LLC"
                            Start="auto"
                            Type="ownProcess"
                            ErrorControl="normal"
                            Account="LocalSystem" />

            <!-- Start on install, stop on upgrade/uninstall, delete on uninstall -->
            <ServiceControl Id="INGAutoListerSvcCtrl"
                            Name="INGAutoLister"
                            Start="install"
                            Stop="both"
                            Remove="uninstall"
                            Wait="no" />
          </Component>

          <!-- Pre-configured credentials template (seeded to ProgramData on first run) -->
          <Component Id="CredentialsComp" Guid="{A2B3C4D5-E6F7-0002-1234-567890ABCDEF}">
            <File Id="CredentialsFile"
                  Source="$(var.SourceDir)credentials.json"
                  KeyPath="yes" />
          </Component>

          <!--
            HKLM Run key: launches the tray helper exe for every user who logs in.
            Startup folder shortcuts only fire for the user who ran the installer;
            HKLM\Run fires for ALL users on every login session.
            The exe detects the service is running, opens the browser, and stays
            resident as a tray icon.
          -->
          <Component Id="StartupRegComp" Guid="{A2B3C4D5-E6F7-0006-1234-567890ABCDEF}">
            <RegistryValue Root="HKLM"
                           Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Run"
                           Name="INGAutoLister"
                           Type="string"
                           Value="[INSTALLFOLDER]AutoListerB1.exe"
                           KeyPath="yes" />
          </Component>

        </Directory>
      </Directory>
    </StandardDirectory>

    <!--
      Framework-dependent runtime files: since PublishSingleFile is off (the bundled single
      exe was getting quarantined by endpoint AV as a false-positive packer/dropper), publish
      now drops ~390 loose files (DLLs, deps.json, etc.) next to AutoListerB1.exe. Harvest
      everything in SourceDir except the two files that are already their own Component above
      (AutoListerB1.exe carries the ServiceInstall; credentials.json gets redacted separately
      by build-installer.ps1).
    -->
    <ComponentGroup Id="RuntimeFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.SourceDir)**">
        <Exclude Files="$(var.SourceDir)AutoListerB1.exe" />
        <Exclude Files="$(var.SourceDir)credentials.json" />
      </Files>
    </ComponentGroup>

    <!-- Desktop shortcut -->
    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopShortcutComp" Guid="{A2B3C4D5-E6F7-0004-1234-567890ABCDEF}">
        <Shortcut Id="DesktopShortcut"
                  Name="ING AutoLister"
                  Description="ING Listing Engine by ING Mining LLC"
                  Target="[INSTALLFOLDER]AutoListerB1.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU"
                       Key="Software\INGMining\AutoLister"
                       Name="DesktopShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <!-- Start Menu shortcut -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="StartMenuING" Name="ING Mining">
        <Component Id="StartMenuShortcutComp" Guid="{A2B3C4D5-E6F7-0005-1234-567890ABCDEF}">
          <Shortcut Id="StartMenuShortcut"
                    Name="ING AutoLister"
                    Description="ING Listing Engine by ING Mining LLC"
                    Target="[INSTALLFOLDER]AutoListerB1.exe"
                    WorkingDirectory="INSTALLFOLDER" />
          <RegistryValue Root="HKCU"
                         Key="Software\INGMining\AutoLister"
                         Name="StartMenuShortcut"
                         Type="integer"
                         Value="1"
                         KeyPath="yes" />
          <RemoveFolder Id="RemoveStartMenuING" Directory="StartMenuING" On="uninstall" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Feature set -->
    <Feature Id="Main" Level="1">
      <ComponentRef Id="MainExeComp" />
      <ComponentRef Id="CredentialsComp" />
      <ComponentRef Id="StartupRegComp" />
      <ComponentGroupRef Id="RuntimeFiles" />
      <ComponentRef Id="DesktopShortcutComp" />
      <ComponentRef Id="StartMenuShortcutComp" />
    </Feature>

  </Package>
</Wix>
