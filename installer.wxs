<?xml version="1.0" encoding="UTF-8"?>
<!--
  ING AutoLister - WiX 7 installer
  Build:  wix build installer.wxs -d SourceDir=.\ING eBay AutoLister\dist\ -o installer-out\ING-AutoLister-Setup.msi
  Prereq: dotnet tool install -g wix && wix eula accept wix7

  Installs per-machine (requires UAC / admin elevation).
    Exe      -> %ProgramFiles%\ING Mining\ING AutoLister\
    Data     -> %LOCALAPPDATA%\ING AutoLister\  (app auto-creates on first run)
  Shortcuts: Desktop, Start Menu, Startup folder (auto-start on login)
  Hosts:     127.0.0.1  inglistingengine.com   (PowerShell CA, runs as SYSTEM)
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package Name="ING AutoLister"
           Manufacturer="ING Mining LLC"
           Version="2.0.0.0"
           UpgradeCode="{7A8F9B2C-3D4E-5F60-A1B2-C3D4E5F6A7B8}"
           Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of ING AutoLister is already installed." />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <!-- Install directory: C:\Program Files\ING Mining\ING AutoLister\ -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="ING_MINING_DIR" Name="ING Mining">
        <Directory Id="INSTALLFOLDER" Name="ING AutoLister">

          <!-- Main executable + Windows service registration -->
          <Component Id="MainExeComp" Guid="{A2B3C4D5-E6F7-0001-1234-567890ABCDEF}">
            <File Id="MainExeFile"
                  Source="$(var.SourceDir)AutoListerB1.exe"
                  KeyPath="yes"
                  Checksum="yes" />

            <!-- Install as a Windows service that auto-starts at boot -->
            <ServiceInstall Id="INGAutoListerSvc"
                            Name="INGAutoLister"
                            DisplayName="ING AutoLister"
                            Description="ING Listing Engine – runs the AutoLister web server on localhost:9330"
                            Start="auto"
                            Type="ownProcess"
                            ErrorControl="normal"
                            Account="LocalSystem" />

            <!-- Start on install, stop on both install (upgrade) and uninstall, delete on uninstall -->
            <ServiceControl Id="INGAutoListerSvcCtrl"
                            Name="INGAutoLister"
                            Start="install"
                            Stop="both"
                            Remove="uninstall"
                            Wait="no" />
          </Component>

          <!-- Pre-configured credentials template (seeded to %LOCALAPPDATA% on first run by the app) -->
          <Component Id="CredentialsComp" Guid="{A2B3C4D5-E6F7-0002-1234-567890ABCDEF}">
            <File Id="CredentialsFile"
                  Source="$(var.SourceDir)credentials.json"
                  KeyPath="yes" />
          </Component>

        </Directory>
      </Directory>
    </StandardDirectory>

    <!-- Startup folder shortcut - auto-starts on user login -->
    <StandardDirectory Id="StartupFolder">
      <Component Id="StartupShortcutComp" Guid="{A2B3C4D5-E6F7-0003-1234-567890ABCDEF}">
        <Shortcut Id="StartupShortcut"
                  Name="ING AutoLister"
                  Description="ING Listing Engine by ING Mining LLC"
                  Target="[INSTALLFOLDER]AutoListerB1.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU"
                       Key="Software\INGMining\AutoLister"
                       Name="StartupShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <!-- Desktop shortcut -->
    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopShortcutComp" Guid="{A2B3C4D5-E6F7-0004-1234-567890ABCDEF}">
        <Shortcut Id="DesktopShortcut"
                  Name="ING AutoLister"
                  Description="ING Listing Engine by ING Mining LLC"
                  Target="[INSTALLFOLDER]AutoListerB1.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU"
                       Key="Software\INGMining\AutoLister"
                       Name="DesktopShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <!-- Start Menu shortcut -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="StartMenuING" Name="ING Mining">
        <Component Id="StartMenuShortcutComp" Guid="{A2B3C4D5-E6F7-0005-1234-567890ABCDEF}">
          <Shortcut Id="StartMenuShortcut"
                    Name="ING AutoLister"
                    Description="ING Listing Engine by ING Mining LLC"
                    Target="[INSTALLFOLDER]AutoListerB1.exe"
                    WorkingDirectory="INSTALLFOLDER" />
          <RegistryValue Root="HKCU"
                         Key="Software\INGMining\AutoLister"
                         Name="StartMenuShortcut"
                         Type="integer"
                         Value="1"
                         KeyPath="yes" />
          <RemoveFolder Id="RemoveStartMenuING" Directory="StartMenuING" On="uninstall" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Feature set -->
    <Feature Id="Main" Level="1">
      <ComponentRef Id="MainExeComp" />
      <ComponentRef Id="CredentialsComp" />
      <ComponentRef Id="StartupShortcutComp" />
      <ComponentRef Id="DesktopShortcutComp" />
      <ComponentRef Id="StartMenuShortcutComp" />
    </Feature>

    <!--
      Hosts file: 127.0.0.1  inglistingengine.com
      SetProperty expands [WindowsFolder] at execute time, then the deferred CA
      runs powershell as SYSTEM (Impersonate=no) to write the hosts entry.
    -->
    <SetProperty Id="RunAddHosts"
                 Before="RunAddHosts"
                 Sequence="execute"
                 Value="powershell -NonInteractive -ExecutionPolicy Bypass -Command &quot;$h='[WindowsFolder]System32\drivers\etc\hosts'; if(-not(Select-String -Path $h -Pattern 'inglistingengine\.com' -Quiet -ErrorAction SilentlyContinue)){ Add-Content $h '127.0.0.1  inglistingengine.com' -Encoding ASCII }&quot;" />

    <CustomAction Id="RunAddHosts"
                  Property="RunAddHosts"
                  ExeCommand=""
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <SetProperty Id="RunRemoveHosts"
                 Before="RunRemoveHosts"
                 Sequence="execute"
                 Value="powershell -NonInteractive -ExecutionPolicy Bypass -Command &quot;$h='[WindowsFolder]System32\drivers\etc\hosts'; $lines=Get-Content $h -ErrorAction SilentlyContinue; if($lines){ ($lines | Where-Object { $_ -notmatch 'inglistingengine' }) | Set-Content $h -Encoding ASCII }&quot;" />

    <CustomAction Id="RunRemoveHosts"
                  Property="RunRemoveHosts"
                  ExeCommand=""
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- Launch the app after install completes (not on upgrade or uninstall) -->
    <CustomAction Id="LaunchApp"
                  FileRef="MainExeFile"
                  ExeCommand=""
                  Execute="deferred"
                  Impersonate="yes"
                  Return="asyncNoWait" />

    <InstallExecuteSequence>
      <Custom Action="RunAddHosts"    After="InstallFiles"    Condition="NOT Installed" />
      <Custom Action="RunRemoveHosts" After="RemoveFiles"     Condition="Installed AND REMOVE~=&quot;ALL&quot;" />
      <Custom Action="LaunchApp"      After="InstallFinalize" Condition="NOT Installed AND NOT REMOVE" />
    </InstallExecuteSequence>

  </Package>
</Wix>
